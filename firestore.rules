rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────
    match /users/{userId} {
      // Anyone authenticated can read any user (for donor search, profiles)
      allow read: if request.auth != null;
      // Users can only write their own profile
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Blood Requests ────────────────────────────────────
    match /blood_requests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      // Owner (recipientId) or any authenticated user can update/delete
      // (admin checks are done app-side)
      allow update, delete: if request.auth != null;
    }

    // ── Chats ─────────────────────────────────────────────
    match /chats/{chatId} {
      allow read, write: if request.auth != null;
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }

    // ── Donations ─────────────────────────────────────────
    match /donations/{donationId} {
      allow read, write: if request.auth != null;
    }

    // ── Notifications ─────────────────────────────────────
    match /notifications/{notificationId} {
      allow read, write: if request.auth != null;
    }

    // ── Alerts ────────────────────────────────────────────
    match /alerts/{alertId} {
      allow read, write: if request.auth != null;
    }

    // ── Admin Settings ────────────────────────────────────
    match /admin_settings/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── API Keys ──────────────────────────────────────────
    match /api_keys/{doc} {
      allow read, write: if request.auth != null;
    }

    // ── Catch-all for other collections ───────────────────
    match /{collection}/{doc} {
      allow read, write: if request.auth != null;
    }
  }
}
